generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
  inactive
}

enum Intensity {
  low
  medium
  high
}

enum GoalStatus {
  not_started
  in_progress
  completed
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  passwordHash      String
  name              String
  profileImageUrl   String?
  gymTeam           String?
  rankBelt          String?
  weightClass       String?
  preferredCategoryIds String[]          @default([])
  stackAuthId       String?              @unique
  stripeCustomerId  String?              @unique
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  subscriptions     Subscription[]
  categories        Category[]
  trainingSessions  TrainingSession[]
  techniqueLogs     TechniqueLog[]
  notes             Note[]
  goals             Goal[]
  achievements      Achievement[]
  bodyMetrics       BodyMetric[]
  strengthMetrics   StrengthMetric[]
  passwordResets    PasswordResetToken[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  stripeCustomerId     String
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(inactive)
  trialStart           DateTime?
  trialEnd             DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([stripeCustomerId])
}

model Category {
  id          String            @id @default(cuid())
  userId      String
  name        String
  slug        String
  isCustom    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingSessions TrainingSession[]
  techniqueLogs    TechniqueLog[]
  notes            Note[]
  goals            Goal[]
  bodyMetrics      BodyMetric[]
  strengthMetrics  StrengthMetric[]

  @@unique([userId, slug])
  @@index([userId])
}

model TrainingSession {
  id                 String      @id @default(cuid())
  userId             String
  categoryId         String
  date               DateTime
  durationMinutes    Int
  intensity          Intensity
  mood               String?
  wins               String?
  needsWork          String?
  notes              String?
  techniquesDrilled  String[]    @default([])
  rollingRounds      Int?
  positionalTraining String?
  submissionsSweeps  String?
  coachFeedback      String?
  exercise           String?
  sets               Int?
  reps               Int?
  weightKg           Float?
  volume             Float?
  isPr               Boolean     @default(false)
  bodyweightKg       Float?
  rounds             Int?
  combos             String?
  drills             String?
  sparring           Boolean?
  cardioMinutes      Int?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category           Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId, categoryId, date])
}

model TechniqueLog {
  id               String    @id @default(cuid())
  userId           String
  categoryId       String
  techniqueName    String
  date             DateTime
  timesDrilled     Int       @default(1)
  confidenceLevel  Int
  successRating    Int
  whatImproved     String?
  whatNeedsWork    String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId, categoryId, date])
  @@index([techniqueName])
}

model Note {
  id           String    @id @default(cuid())
  userId       String
  categoryId   String?
  title        String
  content      String
  pinned       Boolean   @default(false)
  isGlobal     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags         NoteTag[]

  @@index([userId, categoryId, pinned, createdAt])
  @@index([title])
}

model NoteTag {
  id        String   @id @default(cuid())
  noteId    String
  tag       String

  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, tag])
  @@index([tag])
}

model Goal {
  id           String     @id @default(cuid())
  userId       String
  categoryId   String?
  title        String
  description  String?
  targetValue  Float?
  currentValue Float?     @default(0)
  unit         String?
  deadline     DateTime?
  status       GoalStatus @default(not_started)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, categoryId, status])
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  earnedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, earnedAt])
}

model BodyMetric {
  id          String   @id @default(cuid())
  userId      String
  categoryId  String?
  date        DateTime
  weightKg    Float?
  bodyFatPct  Float?
  restingHr   Int?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([categoryId])
}

model StrengthMetric {
  id            String   @id @default(cuid())
  userId        String
  categoryId    String?
  date          DateTime
  exercise      String
  oneRepMaxKg   Float?
  volume        Float?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, exercise, date])
  @@index([categoryId])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
